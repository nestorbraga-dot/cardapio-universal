rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cardápio, categorias e pedidos: liberado para leitura e escrita
    // O controle de acesso é feito via PIN (cliente-side) — sem Firebase Auth
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
