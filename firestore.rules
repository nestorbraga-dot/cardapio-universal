rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Coleção de Produtos: Clientes lêem, apenas Admin edita/deleta
    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // Coleção de Pedidos: Clientes criam pedidos, Admin e Entregadores gerenciam
    match /pedidos/{pedidoId} {
      allow create: if true;
      allow read, update: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.role == 'entregador');
    }
  }
}
